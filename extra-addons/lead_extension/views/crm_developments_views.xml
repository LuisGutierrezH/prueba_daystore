<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View crm.developments View Tree -->
    <record id="view_crm_developments_tree" model="ir.ui.view">
        <field name="name">view.crm.developments.tree</field>
        <field name="model">crm.developments</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- View crm.developments form -->
    <record id="view_crm_developments_form" model="ir.ui.view">
        <field name="name">view.crm.developments.form</field>
        <field name="model">crm.developments</field>
        <field name="arch" type="xml">
            <form string="Crm Developments">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name..."/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View crm.developments search -->
    <record id="view_crm_developments_search" model="ir.ui.view">
        <field name="name">view.crm.developments.search</field>
        <field name="model">crm.developments</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter string="Name" name="name" domain="[]" context="{'group_by':'name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action crm.developments -->
    <record id="action_crm_developments" model="ir.actions.act_window">
        <field name="name">Crm Developments</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">crm.developments</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Crm Developments.
            </p>
        </field>
    </record>

</odoo>
