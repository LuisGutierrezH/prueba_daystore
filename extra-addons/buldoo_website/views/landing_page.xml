<odoo>
    <template id="buldoo_landing_page" name="Buldoo Landing Page">
        <t t-call="website.layout">
            <div id="wrap">

                <!-- HERO -->
                <section class="buldoo-hero">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-6">
                                <h1>Digitalizamos tu empresa con Odoo</h1>
                                <p>
                                    Automatizamos ventas, inventarios y procesos con Odoo,
                                    adaptándolo 100% a la forma en que tu negocio ya trabaja.
                                </p>

                                <a href="#contacto" class="btn btn-primary">
                                    Solicitar cotización
                                </a>
                                <a href="#soluciones" class="btn btn-outline-light ms-3">
                                    Ver soluciones
                                </a>
                            </div>

                            <div class="col-lg-6 text-center">
                                <img
                                  src="/buldoo_website/static/src/img/hero-odoo.jpeg"
                                  class="img-fluid"
                                  alt="Odoo ERP"
                                />
                            </div>
                        </div>
                    </div>
                </section>

                <!-- SOLUCIONES -->
                <section id="soluciones" class="buldoo-section">
                    <div class="container text-center">
                        <h2>Soluciones con Odoo</h2>

                        <div class="row mt-4">
                            <div class="col-md-4">
                                <img src="/buldoo_website/static/src/img/crm.png"/>
                                <h4>CRM</h4>
                                <p>Seguimiento completo de leads y ventas.</p>
                            </div>
                            <div class="col-md-4">
                                <img src="/buldoo_website/static/src/img/pos.png"/>
                                <h4>Punto de Venta</h4>
                                <p>Ventas rápidas integradas a inventarios.</p>
                            </div>
                            <div class="col-md-4">
                                <img src="/buldoo_website/static/src/img/inventory.png"/>
                                <h4>Inventarios</h4>
                                <p>Control total en tiempo real.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- CONTACTO -->
                <section id="contacto" class="buldoo-section bg-light">
                    <div class="container text-center">
                        <h2>Solicita tu cotización</h2>
                        <p>Cuéntanos sobre tu proyecto y te contactamos.</p>

                        <!-- Aquí puedes incrustar tu formulario website_form -->
                    </div>
                </section>

            </div>
        </t>
    </template>
</odoo>
