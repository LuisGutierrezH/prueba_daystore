<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id='form_assigend_recruiter' model='ir.ui.view'>
        <field name='name'>Asignar reclutador</field>
        <field name='model'>assigned_places_opportunity</field>
        <field name='arch' type='xml'>
            <form name="Asignar reclutador">
                <sheet>
                    <group>
                        <field name='position_to_substitution'></field>
                        <field name='recruiter_id'></field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <act_window id="action_assigend_recruiter" name="Asignar reclutador" res_model="assigned_places_opportunity" view_mode="form" target="new" />
</odoo>
