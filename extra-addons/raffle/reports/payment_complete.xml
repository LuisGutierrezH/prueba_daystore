<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <template id="payment_complete">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="crm_lead">
                <t t-call="web.external_layout">
                    <div class="header">
                        <div class="row">
                            <div class="col-2">
                                <img t-if="docs.company_id.logo" t-att-src="image_data_uri(docs.company_id.logo)" height="100" alt="Logo"/>
                            </div>
                            <div class="col-5">
                                <center>
                                    <strong></strong>
                                </center>
                                <br />
                                <div class="table table-bordered">
                                    <center></center>
                                </div>
                            </div>
                            <div class="col-4">
                                <br />
                                <br />
                                <br />
                                <br />
                                <strong>GUADALAJARA JALISCO: <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/>
                                </strong>
                            </div>
                        </div>
                    </div>
                        <strong>RECIBO PAGO DE HONORARIOS </strong>
                    <br />
                    <br />

                    POR MEDIO DE LA PRESENTE SE HACE CONSTAR QUE RECIBIMOS POR PARTE DE <strong>ARMINDA AMORES NAVARRO </strong>
                    EL PAGO POR CONCEPTO DE HONORARIOS POR <strong> <t t-if="crm_lead.honorarium_two_proposal == 0" > <span t-field="crm_lead.honorarium"/></t> <t t-if="crm_lead.honorarium_two_proposal != 0" > <span t-field="crm_lead.honorarium_two_proposal"/> </t> (<span t-field="crm_lead.number_to_words"/>) </strong>  REFERENTE A LA CANCELACIÓN DEL CONTRATO NÚMERO <strong>  155-752437., 
                    VS </strong>  LA EMPRESA DENOMINADA <strong>  VACATION TRAVEL ADVISORY, S.A. de C.V.</strong>
                    <br />
                    <br />

                    <div class="row" style="padding-top: 10px">
                        <div class="col-12">
                            <br />
                            <br />

                            <img t-if="crm_lead.team_id.user_id.digital_signature" t-att-src="image_data_uri(crm_lead.team_id.user_id.digital_signature)" height="100" alt="Logo"/>
                                                        <br />
                            _________________________________________________
                                                        <br />
                            <strong>
                                <span t-field="crm_lead.team_id.user_id.name"/>
                            </strong>
                            <br />
                            <strong> REPRESENTANTE LEGAL </strong>
                            <br />
                            <strong> ASESORES JDX</strong>
                            <br />
                        </div>
                    </div>
                    <br />
                    <br />
                </t>
            </t>
        </t>
    </template>
</odoo>