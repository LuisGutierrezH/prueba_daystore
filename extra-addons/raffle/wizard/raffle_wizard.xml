<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_raffle_wizard_form" model="ir.ui.view">
        <field name="name">raffle.wizard.form</field>
        <field name="model">raffle.wizard</field>
        <field name="arch" type="xml">
            <form string="Tómbola de Lunes">
                <sheet>
                    <group>
                        <field name="product_id"/>
                    </group>
                    <group>
                        <field name="employee_ids" readonly="1">
                            <tree>
                                <field name="name"/>
                                <field name="coins"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_spin" string="Girar Tómbola" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
