<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VISTA DE LISTA (TREE) DEL HISTORIAL -->
    <record id="view_raffle_history_tree" model="ir.ui.view">
        <field name="name">raffle.history.tree</field>
        <field name="model">raffle.history</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="name" />
                <field name="date" />
                <field name="winner_id" />
                <field name="product_id" />
            </tree>
        </field>
    </record>

    <!-- VISTA FORMULARIO DEL HISTORIAL -->
    <record id="view_raffle_history_form" model="ir.ui.view">
        <field name="name">raffle.history.form</field>
        <field name="model">raffle.history</field>
        <field name="arch" type="xml">
            <form string="Histórico de Sorteos" create="0" edit="0" delete="0">
                <header>
                    <button name="action_abrir_wizard" 
                            string="Lanzar Tómbola" 
                            type="object" 
                            class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1" />
                            <field name="date" readonly="1" />
                        </group>
                        <group>
                            <field name="winner_id" readonly="1" />
                            <field name="product_id" readonly="1" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- VISTA DE BÚSQUEDA -->
    <record id="view_raffle_history_search" model="ir.ui.view">
        <field name="name">raffle.history.search</field>
        <field name="model">raffle.history</field>
        <field name="arch" type="xml">
            <search>
                <field name="winner_id" />
                <field name="product_id" />
                <field name="date" />
                <group string="Agrupar por" expand="0">
                    <filter name="group_winner" string="Ganador" context="{'group_by':'winner_id'}" />
                    <filter name="group_product" string="Premio" context="{'group_by':'product_id'}" />
                </group>
            </search>
        </field>
    </record>


    <!-- ACCIÓN DEL HISTORIAL (VISTA) -->
    <record id="action_raffle_history" model="ir.actions.act_window">
        <field name="name">Histórico de Sorteos</field>
        <field name="res_model">raffle.history</field>
        <field name="view_mode">tree,form</field>
    </record>


    <!-- Clic en menú detona función -->
    <record id="action_server_lanzar_tombola" model="ir.actions.server">
        <field name="name">Lanzar Tómbola desde Menú</field>
        <field name="model_id" ref="model_raffle_history"/>
        <field name="state">code</field>
        <field name="code">
action = model.action_menu_lanzar_tombola()
        </field>
    </record>


    <menuitem id="menu_raffle_history" 
              name="Histórico" 
              parent="menu_raffle_root" 
              action="action_raffle_history" 
              sequence="10" />

    <menuitem id="menu_raffle_wizard_direct" 
              name="Lanzar Tómbola" 
              parent="menu_raffle_root" 
              action="action_server_lanzar_tombola" 
              sequence="20" />
</odoo>
